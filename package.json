{
  "name": "yahoo-fantasy-baseball-mcp",
  "version": "0.5.0",
  "description": "MCP server for Yahoo Fantasy Baseball — AI-powered roster management, Statcast analytics, and free-agent scouting via natural language.",
  "type": "module",
  "license": "MIT",
  "author": "dingyiyi0226",
  "homepage": "https://github.com/dingyiyi0226/fantasy-baseball-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dingyiyi0226/fantasy-baseball-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/dingyiyi0226/fantasy-baseball-mcp/issues"
  },
  "bin": {
    "yahoo-fantasy-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "npm run build && node test/run.mjs",
    "auth": "node dist/cli.js auth",
    "serve": "node dist/cli.js serve",
    "pack": "npx -y @anthropic-ai/mcpb pack . yahoo-fantasy-baseball-v$(node -p \"require('./package.json').version\").mcpb",
    "pack:safe": "npm run pack && MCPB=yahoo-fantasy-baseball-v$(node -p \"require('./package.json').version\").mcpb && TMPDIR=$(mktemp -d) && unzip -q \"$MCPB\" -d \"$TMPDIR\" && rm \"$MCPB\" && (cd \"$TMPDIR\" && zip -0 -r - .) > \"$MCPB\" && rm -rf \"$TMPDIR\"",
    "pack:skill": "rm -f fantasy-roster-review-skill.zip && (cd skills && zip -r ../fantasy-roster-review-skill.zip fantasy-roster-review -x '*.DS_Store')",
    "version": "node scripts/sync-version.js && git add manifest.json src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.0",
    "fast-xml-parser": "^4.5.0",
    "selfsigned": "^5.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

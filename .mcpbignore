# Keep the .mcpb bundle small WITHOUT touching files inside node_modules.
# Patterns are gitignore-style and match at any depth, so anchor anything that
# should only apply at the bundle root with a leading slash. (A bare `src/`
# would wrongly strip dependencies' own src/ folders and break them.)

/src/
/api_test/
/.github/
/.git/
/tsconfig.json
/.gitignore
/.mcpbignore
/README.md
/*.mcpb

# Codex plugin packaging — not part of the Claude Desktop bundle.
/.codex-plugin/
/.mcp.json
/.agents/

# Drop our build's sourcemaps and type declarations (not needed at runtime).
/dist/**/*.map
/dist/**/*.d.ts

# Dependency CLIs and OS cruft.
node_modules/.bin/
.DS_Store
